prefix=${pcfiledir}/../..
includedir=${prefix}/include
libdir=${prefix}/lib

Name: avfilter
Description: Audio/video filtering library
Version: 10.4.100
Requires.private: libavutil, libavformat, libavcodec, libswresample, libswscale, zlib
Libs: -L${libdir} -lavfilter
Libs.private: -framework CoreFoundation -framework CoreMedia -framework CoreVideo -framework CoreAudio -lm -lbz2 -framework CoreImage -framework AppKit
Cflags: -I${includedir}

