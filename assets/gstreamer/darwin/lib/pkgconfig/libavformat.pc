prefix=${pcfiledir}/../..
includedir=${prefix}/include
libdir=${prefix}/lib

Name: avformat
Description: Multimedia formats
Version: 61.7.100
Requires.private: libavcodec, libavutil, libswresample, zlib
Libs: -L${libdir} -lavformat
Libs.private: -framework CoreFoundation -framework CoreMedia -framework CoreVideo -framework CoreAudio -lm -lbz2
Cflags: -I${includedir}

