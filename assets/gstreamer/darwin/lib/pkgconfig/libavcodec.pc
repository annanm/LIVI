prefix=${pcfiledir}/../..
includedir=${prefix}/include
libdir=${prefix}/lib

Name: avcodec
Description: Multimedia codecs
Version: 61.19.100
Requires.private: libavutil, libswresample, zlib
Libs: -L${libdir} -lavcodec
Libs.private: -framework CoreFoundation -framework CoreMedia -framework CoreVideo -framework CoreAudio -lm
Cflags: -I${includedir}

